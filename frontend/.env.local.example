# For cross-device demo (student on one laptop, examiner/admin on another):
# 1. Find the host machine's LAN IP: run `ipconfig` (Windows) or `ifconfig` / `ip addr` (Mac/Linux)
# 2. Copy this file to `.env.local` and fill in the IP below
# 3. Do the same on every other device accessing the app

# Replace 192.168.1.100 with the actual IP of the machine running the backend
VITE_API_BASE_URL=http://192.168.1.100:4000

# Leave blank (or delete this file) when running everything on one machine
# VITE_API_BASE_URL=
